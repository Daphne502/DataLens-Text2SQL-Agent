# Supabase（mock 数据脚本用）
SUPABASE_DB_URI=postgresql://user:password@host:5432/postgres

# Dify（FastAPI 用）
DIFY_API_URL=https://api.dify.ai/v1
DIFY_API_KEY=your_dify_app_key

# Supabase RPC（与 Dify 环境变量一致，供本地文档参考）
SUPABASE_RPC_URL=https://xxx.supabase.co/rest/v1/rpc/exec_sql
SUPABASE_ANON_KEY=your_anon_key
